# Service keys
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-realtime-whisper
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# App configuration
ENV=local
PORT=7860
LOCAL_SERVER_URL=https://your-url.ngrok.io
CLAIMS_JSON_PATH=./data/claims.json
SESSION_STORE_PATH=./data/sessions.json
DRY_RUN_CALLS=false
LOG_LEVEL=INFO

# Pipecat Cloud deployment values, only used when ENV=production
AGENT_NAME=claim-status-agent
ORGANIZATION_NAME=
